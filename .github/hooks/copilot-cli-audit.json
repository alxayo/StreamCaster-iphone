{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
       // "bash": "./scripts-cli/session-start.sh",
       // "powershell": "./scripts-cli/session-start.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
       // "bash": "./scripts-cli/commit-prompt.sh",
      //  "powershell": "./scripts-cli/commit-prompt.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 15
      }
    ],
    "preToolUse": [
      {
        "type": "command",
      //  "bash": "./scripts-cli/pre-tool-use.sh",
      //  "powershell": "./scripts-cli/pre-tool-use.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 15
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "./scripts-cli/commit-changes.sh",
        "powershell": "./scripts-cli/commit-changes.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts-cli/finalize-session.sh",
        "powershell": "./scripts-cli/finalize-session.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 30
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "bash": "./scripts-cli/log-error.sh",
        "powershell": "./scripts-cli/log-error.ps1",
        "cwd": ".github/hooks",
        "timeoutSec": 10
      }
    ]
  }
}
