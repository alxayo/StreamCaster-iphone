<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Multitasking Camera Access:
	     Allows the app to keep using the camera even when it's not
	     the foreground app (e.g., during Picture-in-Picture or
	     Split View on iPad). Essential for a streaming app. -->
	<key>com.apple.developer.avfoundation.multitasking-camera-access</key>
	<true/>
</dict>
</plist>
